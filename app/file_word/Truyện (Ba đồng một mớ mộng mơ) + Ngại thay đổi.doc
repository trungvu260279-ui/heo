\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 Khi b\'FD\u7899 ?c qua c\'E1i
 c\u7917 ?a xi\'EAu c\u7911 ?a c\'E3n nh\'E0 xi\'EAu, khi m\u7855 ?t ch\u7883 ? c\u242 ?n ch\'FDa quen v\u7899 ?i c\'E1i
 kh\'F4ng gian t\u7889 ?i t\'E3m b\'EAn trong nh\'E0, c\'E1i m\'E0 ch\u7883 ? nh\u236 ?n r\u245 ? nh\u7845 ?t l\'E0 \'E1nh
 m\u7855 ?t s\'E1ng qu\u7855 ?c c\u7911 ?a th\u7857 ?ng b\'E9. N\'F3 n\u7857 ?m cong queo tr\'EAn gi\'FD\u7901 ?ng, h\'E9o
 nh\'FD m\u7897 ?t \'F0\u7913 ?a tr\u7867 ? l\'EAn n\'E3m. X\'FD\'F5ng n\'F3 nh\'F4 ra m\u7849 ?u n\'E0o c\u361 ?ng b\'E9n
 ng\'F3t. Mi\u7879 ?ng li\'EAn t\u7909 ?c \'F0\u7899 ?p kh\'F4ng kh\'ED, n\'FD\u7899 ?c d\u227 ?i ri r\u7881 ? ch\u7843 ?y
 ra b\'EAn kh\'F3e m\'F4i s\u7847 ?n s\'F9i, th\u7857 ?ng b\'E9 n\u7889 ?i m\u7897 ?t s\u7907 ?i nh\u236 ?n b\u7873 ?n dai
 v\'E0o ch\u7883 ?, h\'FAt ch\u7883 ? \'F0\u7871 ?n ng\u7891 ?i v\u7899 ?i n\'F3. V\'E0 t\u7915 ? \'F0\'F3, n\'F3 kh\'F4ng
 bu\'F4ng tay ch\u7883 ? ra n\u7919 ?a. C\u7913 ? n\'EDu l\u7845 ?y, c\u7913 ? gh\u236 ? ch\u7863 ?t, m\u7855 ?t \u7847 ?ng
 \u7853 ?c n\'FD\u7899 ?c, c\u7893 ? h\u7885 ?ng ph\'E1t ra nh\u7919 ?ng \'E2m thanh gru gru v\'F4 ngh\u297 ?a... th\u7857 ?ng
 b\'E9 t\u7887 ? ra quy\u7871 ?n luy\u7871 ?n kh\'F4ng r\u7901 ?i.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 B\'E0 m\u7865 ? xo\u7855 ?n
 qu\u7847 ?n \u7889 ?ng cao \u7889 ?ng th\u7845 ?p, ch\'E2n r\'F5i ra nh\u7919 ?ng m\u7843 ?ng b\'F9n kh\'F4, n\'F3i th\u7857 ?ng
 nh\u7887 ? \'F0\u227 ? hai m\'FD\'F5i m\u7845 ?y tu\u7893 ?i r\u7891 ?i, b\'E0 kh\'F4ng nh\u7899 ? r\u245 ? v\u236 ? c\'F3
 ngh\u297 ?a g\u236 ? \'F0\'E2u, n\'F3 bao nhi\'EAu tu\u7893 ?i th\u236 ? m\u227 ?i m\u227 ?i nh\'FD \'F0\u7913 ?a tr\u7867 ?
 nh\'FD v\u7847 ?y th\'F4i. Ch\u7883 ? b\u7895 ?ng c\'F3 c\u7843 ?m gi\'E1c c\'E1ch n\u7855 ?m tay n\'E0y, c\'E1ch nh\u236 ?n
 da di\u7871 ?t n\'E0y l\'E0 c\u7911 ?a m\u7897 ?t ch\'E0ng trai. M\'E1u m\'F5 m\u7897 ?ng tr\u7895 ?i d\u7853 ?y.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 N\'EAn ch\u7883 ? n\'E1n
 th\'EAm ch\'FAt n\u7919 ?a trong khi nh\u7919 ?ng t\u236 ?nh nguy\u7879 ?n vi\'EAn kh\'E1c trong nh\'F3m c\'F4ng t\'E1c
 x\u227 ? h\u7897 ?i \'F0\u227 ? l\'EAn xe ng\u7891 ?i ch\u7901 ?. Ch\u7883 ? mu\u7889 ?n bi\u7871 ?t th\u7857 ?ng b\'E9
 s\u7869 ? n\'F3i g\u236 ? v\u7899 ?i ch\u7883 ?. C\'E1i s\u7921 ? ch\u7883 ? s\u7855 ?p \'F0i khi\u7871 ?n n\'F3 k\'EDch
 \'F0\u7897 ?ng d\u7919 ? d\u7897 ?i, c\'F5 th\u7875 ? co gi\u7853 ?t, m\u7863 ?t m\'E9o x\u7879 ?ch, mi\u7879 ?ng h\'E1
 to v\'E0 n\'FD\u7899 ?c d\u227 ?i ch\u7843 ?y ra r\u242 ?ng r\u242 ?ng. N\'F3 \'F0ang c\u7889 ? n\'F3i. Ch\u7883 ? c\u7889 ?
 \'F0\u7907 ?i m\u7897 ?t \'E2m thanh kh\'E1c v\u7899 ?i nh\u7919 ?ng ti\u7871 ?ng gru gru tuy\u7879 ?t v\u7885 ?ng. Ch\u7883 ?
 gh\'E9 tai v\'E0o g\u7847 ?n, r\u7891 ?i g\u7847 ?n h\'F5n n\u7919 ?a, \'F0\u7871 ?n n\u7895 ?i tai ch\u7883 ? g\u7847 ?n
 nh\'FD ch\u7841 ?m m\'F4i n\'F3.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 V\'E0 n\'F3 n\'F3i b\u7853 ?t
 th\'E0nh ti\u7871 ?ng. B\u7857 ?ng t\u7845 ?t c\u7843 ? tinh l\u7921 ?c.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 Ch\u7883 ? ra xe, qu\u7879 ?t
 n\'FD\u7899 ?c m\u7855 ?t ch\u7883 ? g\'FD\u7907 ?ng \'F0\'F9a, tr\u7901 ?i \'F0\u7845 ?t, t\'FD\u7903 ?ng \'F0\'E2u n\'F3
 m\'EA m\u236 ?nh. \'D0\'F9a, v\u236 ? ch\u7883 ? kh\'F4ng m\'F5 m\u7897 ?ng \'F0\u7871 ?n v\u7853 ?y, ch\u7883 ? mong n\'F3
 n\'F3i \'93\u7902 ? ch\'F5i!\'94, nh\'FDng su\u7889 ?t bu\u7893 ?i ng\u7891 ?i v\u7899 ?i th\u7857 ?ng b\'E9, th\u7845 ?y
 n\'F3 nh\u236 ?n m\u236 ?nh khi d\u7883 ?u d\'E0ng khi r\'E1t b\u7887 ?ng, l\'E0m nh\u7919 ?ng c\u7917 ? ch\u7881 ? khi
 tr\u236 ?u m\u7871 ?n khi ri\u7871 ?t r\'F3ng, ch\u7883 ? kh\'F4ng bao gi\u7901 ? t\'FD\u7903 ?ng t\'FD\u7907 ?ng l\'E0
 n\'F3 n\'F3i \'93TI\'CAN!\'94.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 C\'F3 ng\'FD\u7901 ?i nghe
 chuy\u7879 ?n n\'F3i \'F0\'E1ng \'F0\u7901 ?i, ai bi\u7875 ?u l\u227 ?ng m\u7841 ?n chi.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 Nh\u7899 ? h\u7891 ?i m\u7899 ?i
 l\u7845 ?y ch\u7891 ?ng, ch\u7883 ? mua t\u7863 ?ng m\u7865 ? ch\u7891 ?ng \u7903 ? qu\'EA c\'E1i n\u7891 ?i c\'F5m \'F0i\u7879 ?n.
 M\u7865 ? \'F0em c\u7845 ?t v\u236 ? \'93n\u7845 ?u c\'E1i n\'E0y kh\'F4ng c\'F3 c\'F5m ch\'E1y v\u7899 ?i n\'FD\u7899 ?c
 c\'F5m cho t\u7909 ?i nh\u7887 ? chan.\'94. T\u7863 ?ng m\u7865 ? m\u7845 ?y b\u7897 ? \'F0\u7891 ? b\'E0 c\u361 ?ng kh\u7893 ?
 s\u7903 ? ph\'E2n tr\u7847 ?n, \'93m\'E0u s\'E1ng qu\'E1 m\'E1 ra v\'FD\u7901 ?n s\u7907 ? d\'EDnh m\u7911 ? chu\u7889 ?i.\'94.
 Ch\u7883 ? mua truy\u7879 ?n tranh \'F0em v\u7873 ? cho b\u7847 ?y em, t\u7909 ?i n\'F3 h\'E1o h\u7913 ?c c\u7847 ?m l\'EAn
 r\u7891 ?i h\u7887 ?i b\u7857 ?ng gi\u7885 ?ng h\'E1o h\u7913 ?c h\'F5n n\u7919 ?a, \'93ch\u7883 ? hai c\'F3 mua b\'E1nh
 m\u236 ? kh\'F4ng?\'94. C\u7913 ? tr\u7899 ?t qu\u7899 ?t v\u7853 ?y. M\u7895 ?i l\u7847 ?n nh\u236 ?n b\u236 ?nh hoa v\u7843 ?i
 ch\u7883 ? mang v\u7873 ? m\u7865 ? l\u7845 ?y t\'FAi ni l\'F4ng b\u7885 ?c l\u7841 ?i cho kh\u7887 ?i b\u7909 ?i, cho n\'F3
 \'F0\u7905 ? ch\'F3i l\'EAn \'F0\'F5n \'F0\u7897 ?c gi\u7919 ?a c\'E3n nh\'E0 v\'E1ch l\'E1, ch\u7883 ? c\'F3 ch\'FAt m\u7855 ?c
 c\u7905 ?. Gi\u7901 ? th\u236 ? ch\u7883 ? ch\u7881 ? mua \'F0\'FD\u7901 ?ng, n\'FD\u7899 ?c m\u7855 ?m. v\'E0 ch\u7855 ?c
 ch\u7855 ?n ch\'FAng \'F0\'FD\u7907 ?c h\u7891 ? h\u7903 ?i \'F0\'F3n nh\u7853 ?n. \'D0\'F4i l\u7847 ?n ch\u7883 ? th\u7845 ?y
 h\'F5i cay \'F0\u7855 ?ng, \'F0\u7901 ?i ng\'FD\u7901 ?i sao ch\u7881 ? qu\u7849 ?n quanh v\u7899 ?i nh\u7919 ?ng th\u7913 ?
 t\u7847 ?m th\'FD\u7901 ?ng b\u7897 ?t ng\u7885 ?t, x\'E0 b\'F4ng.}
\par
\pard\plain\qj\fi620\sl-274\slmult0\wrapdefault\s44\aspalpha\aspnum\faauto\adjustright\cgrid\f0\b0\i\ul0\strike0\scaps0\fs22\afs22
{\cs24\lang1066\langfe1066\f1\b0\i\ul0\strike0\scaps0\fs22\afs22\charscalex100\expndtw0\cf1\dn0 Tr\'FD\u7899 ?c h\'F4m m\u7865 ?
 ch\u7891 ?ng qua \'F0\u7901 ?i, b\'E0 vi\u7871 ?t c\'E1i th\'FD. Ch\u7883 ? v\u7915 ?a \'F0\u7885 ?c v\u7915 ?a kh\'F3c.
 Th\'FD ch\u7881 ? d\u7863 ?n chuy\u7879 ?n ti\u7873 ?n nong, \'F0\u7845 ?t \'F0ai. L\u7901 ?i cu\u7889 ?i c\'F9ng, nh\'FD
 ch\u7883 ? v\u7851 ?n th\'FD\u7901 ?ng quen \'F0\u7885 ?c \u7903 ? \'F0\'E2u \'F0\'F3, r\u7857 ?ng \'93m\u7865 ? \'F0\u7875 ?
 l\u7841 ?i mu\'F4n v\'E0n t\u236 ?nh y\'EAu th\'FD\'F5ng cho c\'E1c con\'94, th\u236 ? m\u7865 ? ch\u7891 ?ng ch\u7883 ?
 vi\u7871 ?t \'93b\u7887 ? l\u7895 ?i cho m\'E1, v\u236 ? m\'E1 m\'F3t \'F0\'FD\u7907 ?c c\'F3 nhi\'EAu \'F0\'F3, chia cho
 t\u7909 ?i con h\'F5i kh\'F3.\'94. Ch\u7883 ? bi\u7871 ?t l\'E0 m\u7865 ? th\'FD\'F5ng con theo ki\u7875 ?u c\u7911 ?a m\u7865 ?,
